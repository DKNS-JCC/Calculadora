# Copy this file to `keystore.properties` (same folder) and fill in your values.
# `keystore.properties` is gitignored — never commit it.

# Absolute path to your release keystore (the .jks file, kept OUTSIDE the repo)
storeFile=D:/3DCC/3dcalc-release.jks

# Keystore password
storePassword=

# Alias used when generating the key (default in our setup: 3dcalc)
keyAlias=3dcalc

# Key password (usually same as storePassword)
keyPassword=
